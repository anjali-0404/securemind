{
  "version": 2,
  "framework": null,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python@4.3.0"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build@3.0.8",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
